{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "src/**/*.tsx",
    ".storybook/**/*.ts",
    "scripts/**/*.ts",
    "*.config.ts",
    "nuxt.ts",
    "nuxt.d.ts",
    "eslint.config.ts",
    "playground/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
