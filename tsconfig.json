{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "playground/**/*.ts",
    "playground/**/*.vue",
    ".storybook/**/*.ts",
    "vitest.config.ts",
    "vite.config.ts",
    "vite.lib.config.ts",
    "vite.playground.config.ts"
  ],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
